# ================================
# Event-Driven Notification Hub
# ================================

# Server
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# Authentication
API_KEYS=dev-key-1
ADMIN_API_KEY=admin-secret-key-change-me
DEFAULT_TENANT_ID=default

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/notification_hub
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5433/notification_hub_test

# Kafka / Redpanda
KAFKA_BROKERS=localhost:19092
KAFKA_GROUP_ID=notification-hub
KAFKA_TOPICS=events.*

# Email (Resend)
RESEND_API_KEY=re_development_key
RESEND_FROM=notifications@kingsleyonoh.com

# Processing
DEDUP_WINDOW_MINUTES=60
DIGEST_SCHEDULE=daily
QUIET_HOURS_CHECK_INTERVAL_MS=900000
NOTIFICATION_RETENTION_DAYS=90

# Personal Setup (optional — for setup:personal script)
# KINGSLEY_RESEND_KEY=re_xxx
# KINGSLEY_RESEND_FROM=notifications@kingsleyonoh.com
# KINGSLEY_TELEGRAM_BOT_TOKEN=123456:ABC-DEF
# KINGSLEY_TELEGRAM_BOT_USERNAME=MyNotifBot
# KINGSLEY_EMAIL=kingsley@example.com
