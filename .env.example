# ================================
# Event-Driven Notification Hub
# ================================

# Server
PORT=3000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/notification_hub

# Kafka / Redpanda
KAFKA_BROKERS=localhost:9092
KAFKA_GROUP_ID=notification-hub
KAFKA_TOPICS=domain.events.*

# Email (Resend)
RESEND_API_KEY=xxxxx
RESEND_FROM=notifications@example.com

# Authentication
API_KEYS=dev-key-1,dev-key-2

# Processing
DEDUP_WINDOW_MINUTES=60
DIGEST_SCHEDULE=hourly

# Enable demo security protections (rate limits, usage caps). See CODING_STANDARDS.md § Public Demo Security.
DEMO_MODE=true
